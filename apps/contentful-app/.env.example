# Content-preview route (…/?entryId=…). Vite exposes VITE_* to the client bundle.
# Copy to `.env` (gitignored). The CPA token is read-only (preview) — low risk, but the
# build inlines it into the client JS, so treat it as semi-public; never commit `.env`.

VITE_CONTENTFUL_SPACE_ID=
VITE_CONTENTFUL_ENVIRONMENT=master
# Content Preview API token: Settings → API keys → your key → "Content Preview API - access token".
VITE_CONTENTFUL_CPA_TOKEN=
